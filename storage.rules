rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth()
          && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isImageUnderLimit() {
      return request.resource.size < 10 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    function isVideoUnderLimit() {
      return request.resource.size < 100 * 1024 * 1024
          && request.resource.contentType.matches('video/.*');
    }

    function isImageOrVideo() {
      return isImageUnderLimit() || isVideoUnderLimit();
    }

    // ── 1. User avatars ─────────────────────────────────────────────
    // Path: avatars/{uid}/{filename}
    // Only the owning user may read or write their own avatar.
    match /avatars/{uid}/{allPaths=**} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid) && isImageUnderLimit();
    }

    // ── 2. Per-user private files ───────────────────────────────────
    // Path: users/{uid}/...
    // Only the owning user may read or write files under their tree.
    match /users/{uid}/{allPaths=**} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid) && isImageOrVideo();
    }

    // ── 3. Projects ─────────────────────────────────────────────────
    // Paths used by the codebase:
    //   projects/{slug}/logo/{filename}
    //   projects/{pid}/roadmap/{rid}/attachments/{filename}
    //   projects/{pid}/tasks/{tid}/attachments/{filename}
    // Any authenticated user may read or write.
    match /projects/{pid}/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAuth() && isImageOrVideo();
    }

    // ── 4. Feedback assets ──────────────────────────────────────────
    // Paths used by the codebase:
    //   feedback/screens/{projectId}/{feedbackItemId}/{filename}
    //   feedback/videos/{projectId}/{feedbackItemId}/{filename}
    //   feedback/{type}s/{projectId}/{feedbackItemId}/v{n}_{filename}
    // Any authenticated user may read or write.
    match /feedback/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAuth() && isImageOrVideo();
    }

    // ── 5. Video screenshots (feedback tool) ────────────────────────
    // Path: video-screenshots/{projectId}/{timestamp}.jpg
    // Any authenticated user may read or write.
    match /video-screenshots/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAuth() && isImageUnderLimit();
    }

    // ── 6. Moodboards ───────────────────────────────────────────────
    // Path: moodboards/{mid}/...
    // Any authenticated user may read or write.
    match /moodboards/{mid}/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAuth() && isImageOrVideo();
    }

    // ── 7. Brands ───────────────────────────────────────────────────
    // Path: brands/{brandSlug}/{field}/{filename}
    // Any authenticated user can read. Only admins may write.
    // NOTE: admin write is verified via a Firestore lookup on the
    // user document's `role` field (no custom claims needed).
    match /brands/{bid}/{allPaths=**} {
      allow read:  if isAuth();
      allow write: if isAdmin() && isImageUnderLimit();
    }

    // ── Default: deny everything else ───────────────────────────────
    // Any path not matched above is implicitly denied (Firebase default).
  }
}
