rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // All authenticated users can read the users list (needed for board members,
    // mentions, etc.). Only owners and admins can update their own documents.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── User settings ─────────────────────────────────────────────────────────
    match /userSettings/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ── Boards ────────────────────────────────────────────────────────────────
    match /boards/{boardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Stages ────────────────────────────────────────────────────────────────
    match /stages/{stageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Tags ──────────────────────────────────────────────────────────────────
    match /tags/{tagId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── Comments ──────────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ── Activities ────────────────────────────────────────────────────────────
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── Time logs ─────────────────────────────────────────────────────────────
    match /time_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Brands ────────────────────────────────────────────────────────────────
    match /brands/{brandId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ── Clients ───────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ── Invoices ──────────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ── Estimates ─────────────────────────────────────────────────────────────
    match /estimates/{estimateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ── Roadmap ───────────────────────────────────────────────────────────────
    match /roadmap/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ── Moodboards ────────────────────────────────────────────────────────────
    match /moodboards/{moodboardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /moodboard_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── Feedback ──────────────────────────────────────────────────────────────
    // feedbackItems are stored under projects/{projectId}/feedbackItems/{itemId}
    match /projects/{projectId}/feedbackItems/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /feedbackComments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ── Email Templates ───────────────────────────────────────────────────────
    match /emailTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isAdmin();
    }

    // ── Calendar Events ───────────────────────────────────────────────────────
    match /calendar_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ── Social ────────────────────────────────────────────────────────────────
    match /social_accounts/{accountId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }

    match /social_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /scheduled_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    match /social_anomalies/{anomalyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Social Auth tokens (server-side only) ─────────────────────────────────
    match /socialTokens/{platform} {
      allow read, write: if false;
    }

    // ── Social metrics cache (server-written only) ────────────────────────────
    match /socialMetrics/{clientId}/{platform} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAdmin();
    }

    // ── Project Links ─────────────────────────────────────────────────────────
    match /projectLinks/{linkId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ── Proposals ─────────────────────────────────────────────────────────────
    match /proposals/{proposalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['title', 'submitterId']) &&
        request.resource.data.submitterId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.submitterId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Catch-all: DENY everything not explicitly listed above ────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
